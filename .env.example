# LLM API configuration (supports any OpenAI SDK-compatible provider)
# Optional recommendation: Qwen Plus via Alibaba Bailian: https://bailian.console.aliyun.com/
# Cost note: start with fewer than 40 rounds for initial trials
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP memory graph configuration =====
# Free-tier quota is enough for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM configuration (optional) =====
# If not used, leave the following boost variables unset
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Multi-AI Consensus Validators (Optional) =====
# Validator AI #2 (e.g. Anthropic Claude via OpenAI-compatible endpoint)
LLM_VALIDATOR_2_API_KEY=
LLM_VALIDATOR_2_BASE_URL=
LLM_VALIDATOR_2_MODEL_NAME=

# Validator AI #3 (e.g. Google Gemini via OpenAI-compatible endpoint)
LLM_VALIDATOR_3_API_KEY=
LLM_VALIDATOR_3_BASE_URL=
LLM_VALIDATOR_3_MODEL_NAME=

# ===== Simulation Speed Mode =====
SIMULATION_SPEED_MODE=normal

# ===== Geopolitical Event Injection =====
ENABLE_GEOPOLITICAL_EVENTS=true